{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LlmJudge Criteria File",
  "description": "Schema for criteria JSON files stored in S3",
  "type": "object",
  "required": ["criteria"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable name for this criteria set"
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_]+$",
            "description": "Criterion identifier (alphanumeric + underscore)"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "What this criterion measures"
          },
          "evaluation_prompt": {
            "type": "string",
            "description": "Additional guidance for the judge LLM on how to score this criterion"
          },
          "score_descriptors": {
            "type": "object",
            "description": "Score-to-descriptor mapping for scoring guidance",
            "additionalProperties": {
              "type": "string"
            }
          },
          "evaluation_steps": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Ordered list of yes/no questions or checks the judge LLM must work through before scoring. When present, the LLM returns per-step reasoning alongside the final score."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "name": "Technical Evaluation",
      "criteria": [
        {
          "name": "accuracy",
          "description": "Factual correctness of the response",
          "evaluation_prompt": "Evaluate whether all technical claims are correct",
          "score_descriptors": {
            "1": "Major factual errors",
            "5": "Completely accurate and verifiable"
          }
        },
        {
          "name": "clarity",
          "description": "Clarity and readability of the explanation"
        }
      ]
    }
  ]
}
